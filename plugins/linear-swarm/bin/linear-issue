#!/usr/bin/env bash
# linear-issue — query and update Linear issues for linear-swarm

set -euo pipefail

for f in "$HOME/.zshenv" "$HOME/.bashrc" "$HOME/.profile"; do
  [ -f "$f" ] && set -a && source "$f" 2>/dev/null && set +a
done

SCRIPT_DIR="$(cd "$(dirname "$0")/../scripts" && pwd)"
exec python3 "$SCRIPT_DIR/linear_api.py" --key "${LINEAR_API_KEY:-}" "$@"
