#!/usr/bin/env bash
# Compatibility shim. The Daytona worker lane was replaced by sandbox-worker.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

printf 'linear-swarm: daytona-worker is deprecated; using sandbox-worker on Vercel Sandbox instead.\n' >&2
exec "${SCRIPT_DIR}/sandbox-worker" "$@"
