{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LINEAR_SWARM_SOFT_FAIL=1 \"${CLAUDE_PLUGIN_ROOT}/scripts/ensure_runtime.sh\""
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/preflight.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "linear-swarm",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/linear_swarm_gate.sh\""
          }
        ]
      }
    ]
  }
}
